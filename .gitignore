# ─── Backend (Maven / Java) ───────────────────────────────────────────────────
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
*.class
*.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ─── Frontend (Node / Vite) ───────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ─── IDE / OS ─────────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
.DS_Store
Thumbs.db

# ─── Env files (never commit secrets) ────────────────────────────────────────
.env
.env.local
.env.*.local
backend/.env
# .env.example files ARE committed (they contain no real values)
!**/.env.example
