# ─────────────────────────────────────────────────────────────────────────────
# .env.example  –  Template for local development secrets
#
# ✅ This file IS committed to Git (it has no real values).
# ✅ Copy it to .env and fill in your real keys before running the app.
#
#   cp .env.example .env   (Mac/Linux)
#   copy .env.example .env (Windows)
# ─────────────────────────────────────────────────────────────────────────────

# Get your Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Your local MySQL root password (must match application.properties)
DB_PASSWORD=
